---
import { getLocalSessionPorts } from '../utils/ports';

interface Props {
	src: string;
	title: string;
	buttonLabel?: string;
}

const { src, title, buttonLabel = 'Fullscreen' } = Astro.props;

// Development HMR logic: 
// If we are in DEV mode, try to find a local port for this session
let finalSrc = src;
if (import.meta.env.DEV) {
	const sessionPorts = getLocalSessionPorts();
	// Extract slug from src (e.g., "/slides/resume-building-101/" -> "resume-building-101")
	const slugMatch = src.match(/\/slides\/([^/]+)\/?/);
	const slug = slugMatch ? slugMatch[1] : null;
	
	if (slug && sessionPorts[slug]) {
		finalSrc = `http://localhost:${sessionPorts[slug]}${src}`;
	}
}
---

<div class="slides-embed-card" data-slides-embed>
	<div class="slides-embed-toolbar">
		<button
			type="button"
			class="slides-embed-fullscreen-btn"
			data-slides-fullscreen-btn
			aria-label={buttonLabel}
			title={buttonLabel}
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="slides-embed-fullscreen-icon">
				<path d="M4 9V4h5v2H6v3H4zm14 0V6h-3V4h5v5h-2zM4 15h2v3h3v2H4v-5zm14 3v-3h2v5h-5v-2h3z" />
			</svg>
			<span class="hr-sr-only">{buttonLabel}</span>
		</button>
	</div>
	<iframe
		class="slides-embed"
		src={finalSrc}
		title={title}
		allow="fullscreen"
		allowfullscreen
		loading="lazy"
	/>
</div>

<script is:inline>
	(() => {
		const cards = document.querySelectorAll('[data-slides-embed]');
		for (const card of cards) {
			const btn = card.querySelector('[data-slides-fullscreen-btn]');
			if (!(btn instanceof HTMLButtonElement)) continue;
			if (btn.dataset.bound === 'true') continue;

			btn.dataset.bound = 'true';
			btn.addEventListener('click', async () => {
				try {
					if (document.fullscreenElement) {
						await document.exitFullscreen();
						return;
					}
					if (typeof card.requestFullscreen === 'function') {
						await card.requestFullscreen();
						return;
					}
					if (typeof card.webkitRequestFullscreen === 'function') {
						card.webkitRequestFullscreen();
					}
				} catch {
					const frame = card.querySelector('iframe');
					if (frame instanceof HTMLIFrameElement && frame.src) {
						window.open(frame.src, '_blank', 'noopener,noreferrer');
					}
				}
			});
		}
	})();
</script>
