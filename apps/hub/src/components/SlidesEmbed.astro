---
import { getLocalSessionPorts } from '../utils/ports';

interface Props {
	src: string;
	title: string;
	buttonLabel?: string;
}

const { src, title, buttonLabel = 'Fullscreen' } = Astro.props;

// Extract session identifier from URL path (e.g., "/slides/resume-101/" -> "resume-101")
const sessionName = src.split('/')[2];

// In development, resolve the specific local port for the requested session
const localPorts = import.meta.env.DEV ? getLocalSessionPorts() : {};
const port = sessionName ? localPorts[sessionName] : undefined;

// Direct local proxying: Bypass the Astro middleware in dev mode to prevent Vite HMR conflicts.
// The original path is preserved to ensure parity with Vercel's production routing.
const finalSrc = import.meta.env.DEV && port 
    ? `http://localhost:${port}${src}`
    : src;
---

<div class="slides-embed-card" data-slides-embed>
	<div class="slides-embed-toolbar">
		<button
			type="button"
			class="slides-embed-fullscreen-btn"
			data-slides-fullscreen-btn
			aria-label={buttonLabel}
			title={buttonLabel}
			data-tooltip={buttonLabel}
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="slides-embed-fullscreen-icon">
				<path d="M4 9V4h5v2H6v3H4zm14 0V6h-3V4h5v5h-2zM4 15h2v3h3v2H4v-5zm14 3v-3h2v5h-5v-2h3z" />
			</svg>
			<span class="hr-sr-only">{buttonLabel}</span>
		</button>
	</div>
	<iframe
		class="slides-embed"
		src={finalSrc}
		title={title}
		allow="fullscreen"
		allowfullscreen
		loading="lazy"
	/>
</div>

<script is:inline>
	(() => {
		const cards = document.querySelectorAll('[data-slides-embed]');
		for (const card of cards) {
			const btn = card.querySelector('[data-slides-fullscreen-btn]');
			if (!(btn instanceof HTMLButtonElement)) continue;
			if (btn.dataset.bound === 'true') continue;

			btn.dataset.bound = 'true';
			btn.addEventListener('click', async () => {
				const target = card;
				try {
					if (document.fullscreenElement) {
						await document.exitFullscreen();
						return;
					}
					if (typeof target.requestFullscreen === 'function') {
						await target.requestFullscreen();
						return;
					}
					if (typeof target.webkitRequestFullscreen === 'function') {
						target.webkitRequestFullscreen();
					}
				} catch {
					const frame = card.querySelector('iframe');
					if (frame instanceof HTMLIFrameElement && frame.src) {
						window.open(frame.src, '_blank', 'noopener,noreferrer');
					}
				}
			});
		}
	})();
</script>
