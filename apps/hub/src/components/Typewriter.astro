---
interface Props {
	text: string;
	phrases?: string[];
	delay?: number;
	speed?: number;
	eraseSpeed?: number;
	minWait?: number;
	maxWait?: number;
	charsPerLine?: number;
}

const { 
	text, 
	phrases = [], 
	delay = 500, 
	speed = 120, 
	eraseSpeed = 60,
	minWait = 5000,
	maxWait = 10000,
	charsPerLine = 14 // Increased to 15
} = Astro.props;

/**
 * Smart Word Wrap: Breaks at spaces or forces break if word exceeds limit.
 */
function wrapText(str: string, limit: number) {
	const words = str.split(' ');
	let lines: string[] = [];
	let currentLine = '';

	words.forEach(word => {
		if ((currentLine + (currentLine ? ' ' : '') + word).length > limit) {
			if (currentLine) lines.push(currentLine);
			let remainingWord = word;
			while (remainingWord.length > limit) {
				lines.push(remainingWord.substring(0, limit));
				remainingWord = remainingWord.substring(limit);
			}
			currentLine = remainingWord;
		} else {
			currentLine += (currentLine ? ' ' : '') + word;
		}
	});
	if (currentLine) lines.push(currentLine);
	return lines.join('\n');
}

const allPhrases = [text, ...phrases.filter(p => p !== text)].map(p => wrapText(p, charsPerLine));

// Calculate master ghost: Max lines across ALL phrases
const maxLines = Math.max(...allPhrases.map(p => p.split('\n').length));
// Create a ghost string with enough newlines to reserve the maximum vertical space
const ghostContent = Array(maxLines).fill(' ').join('\n');
---

<div 
	class="typewriter-wrapper" 
	data-phrases={JSON.stringify(allPhrases)}
	data-speed={speed} 
	data-erase-speed={eraseSpeed}
	data-delay={delay}
	data-min-wait={minWait}
	data-max-wait={maxWait}
>
	<span class="hr-sr-only">{text}</span>
	
	<div class="typewriter-container" aria-hidden="true">
		<!-- Ghost reserves the maximum vertical space permanently -->
		<pre class="typewriter-ghost">{ghostContent}</pre>
		
		<!-- Typed text is stacked on top, right-aligned -->
		<pre class="typewriter-typed"></pre>
	</div>
</div>

<script>
	function initTypewriter() {
		const wrappers = document.querySelectorAll('.typewriter-wrapper');
		
		wrappers.forEach(wrapper => {
			const typedEl = wrapper.querySelector('.typewriter-typed') as HTMLElement;
			if (!typedEl) return;

			const phrases = JSON.parse(wrapper.getAttribute('data-phrases') || '[]');
			const speed = parseInt(wrapper.getAttribute('data-speed') || '120');
			const eraseSpeed = parseInt(wrapper.getAttribute('data-erase-speed') || '60');
			const initialDelay = parseInt(wrapper.getAttribute('data-delay') || '500');
			const minWait = parseInt(wrapper.getAttribute('data-min-wait') || '2000');
			const maxWait = parseInt(wrapper.getAttribute('data-max-wait') || '5000');
			
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			let phraseIndex = 0;
			let charIndex = 0;
			let isDeleting = false;
			let usedPhrases = new Set<number>();

			if (prefersReducedMotion) {
				typedEl.textContent = phrases[0];
				return;
			}

			function getRandomPhrase() {
				if (usedPhrases.size === phrases.length) {
					usedPhrases.clear();
				}
				
				let randomIndex;
				do {
					randomIndex = Math.floor(Math.random() * phrases.length);
				} while (usedPhrases.has(randomIndex));
				
				usedPhrases.add(randomIndex);
				return randomIndex;
			}

			function updateDisplay(currentPhrase: string, index: number, cursorChar: string, isBlinking = false) {
				const typedPart = currentPhrase.slice(0, index);
				const untypedPart = currentPhrase.slice(index + (isDeleting ? 0 : 1));
				const cursorClass = isBlinking ? 'typewriter-inline-cursor blink' : 'typewriter-inline-cursor';
				
				// Keep full string length for stable right alignment
				// Untyped part is invisible but occupies space
				typedEl.innerHTML = `${typedPart}<span class="${cursorClass}">${cursorChar}</span><span style="visibility:hidden">${untypedPart}</span>`;
			}

			function tick() {
				const currentPhrase = phrases[phraseIndex];
				
				if (isDeleting) {
					if (charIndex > 0) {
						charIndex--;
						updateDisplay(currentPhrase, charIndex, currentPhrase[charIndex] || '');
						setTimeout(tick, eraseSpeed);
					} else {
						isDeleting = false;
						phraseIndex = getRandomPhrase();
						setTimeout(tick, 500);
					}
				} else {
					if (charIndex < currentPhrase.length) {
						let charToShow = currentPhrase[charIndex];
						
						if (charToShow === '\n') {
							charIndex++;
							charToShow = currentPhrase[charIndex] || '';
						}

						updateDisplay(currentPhrase, charIndex, charToShow);
						charIndex++;
						setTimeout(tick, speed);
					} else {
						updateDisplay(currentPhrase, charIndex, '', true);
						isDeleting = true;
						const waitTime = Math.floor(Math.random() * (maxWait - minWait + 1)) + minWait;
						setTimeout(tick, waitTime);
					}
				}
			}

			setTimeout(tick, initialDelay);
		});
	}

	initTypewriter();
	document.addEventListener('astro:after-swap', initTypewriter);
</script>
