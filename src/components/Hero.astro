---
import type { Props } from '@astrojs/starlight/props';
import Typewriter from './Typewriter.astro';

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, actions = [] } = data.hero || {};
---

<div class="hero">
	<div class="hero-content">
		<h1 class="hero-title">{title}</h1>
		{tagline && <p class="hero-tagline">{tagline}</p>}
		{actions.length > 0 && (
			<div class="hero-actions">
				{actions.map((action) => (
					<a 
						href={action.link} 
						class={`hero-btn hero-btn-${action.variant || 'primary'}`}
					>
						{action.text}
					</a>
				))}
			</div>
		)}
	</div>
	<div class="hero-logo-section">
		<img 
			src="/src/assets/logo-light-wide.svg" 
			alt="HackerRank Logo" 
			class="hero-logo"
		/>
		<div class="hero-divider"></div>
		<Typewriter 
			text="Crew GDL" 
			phrases={[
				"Aprende", 
				"Evoluciona", 
				"Mondongo", 
				"Skill over pedigree", 
				"No soy un robot", 
				"The Game", 
				"Renataaa", 
				"C++ > Python", 
				"Become a Next-Gen Developer",
				"Todo es un grafo si lo piensas bien",
				"It works on my machine ¯\(ツ)/¯",
				"Hello, World!",
				"127.0.0.1 Sweet Home.",
				"Binary Search go brrr",
				"Calzada Independencia Survivor",
				"Si ves esto, es que hay un bug :(",
				"Centrando el div...",
				"The cake is a lie",
				"404: Motivation not found",
				"git commit -m 'Initial commit'",
				"git push origin main",
				"sudo rm -rf / --no-preserve-root",
				"System.out.println('Hello, World!');",
				"print('Hello, World!')",
				"console.log('Hello, World!');",
				"echo 'Hello, World!'",
				"Gemini dame más frases porfa",
				"DROP TABLE users;",
				"sudo apt-get install hackerRank",
				"npm install -g hackerRank",
				"pip install hackerRank",
				"brew install hackerRank",
			]} 
		/>
	</div>
</div>
