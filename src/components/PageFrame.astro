					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="M13.5 22v-8.2h2.77l.42-3.2H13.5V8.56c0-.93.26-1.56 1.6-1.56h1.7V4.13A22 22 0 0 0 14.33 4c-2.45 0-4.13 1.5-4.13 4.23v2.36H7.42v3.2h2.78V22h3.3z"/>
