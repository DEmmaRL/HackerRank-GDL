---
import Default from '@astrojs/starlight/components/PageFrame.astro';
import SocialIcon from './SocialIcon.astro';
import { inject } from '@vercel/analytics';

inject();

const currentYear = new Date().getFullYear();
---

<div class="hr-app-shell">
	<Default>
		<slot />
		<slot name="header" slot="header" />
		<slot name="sidebar" slot="sidebar" />
	</Default>

	<footer class="hr-global-footer" role="contentinfo" aria-label="HackerRank Crew GDL footer">
		<div class="hr-global-footer__inner">
			<p>HackerRank Crew GDL · {currentYear}</p>
			<nav aria-label="Redes sociales HackerRank Crew GDL">
				<a class="hr-social-icon-link" href="https://www.linkedin.com/company/hackerrank-crew-gdl" target="_blank" rel="noreferrer noopener" aria-label="LinkedIn">
					<SocialIcon name="linkedin" />
				</a>
				<a class="hr-social-icon-link" href="https://discord.com/invite/xSQN5sJP6M" target="_blank" rel="noreferrer noopener" aria-label="Discord">
					<SocialIcon name="discord" />
				</a>
				<a class="hr-social-icon-link" href="http://instagram.com/hackerrank.gdl/" target="_blank" rel="noreferrer noopener" aria-label="Instagram">
					<SocialIcon name="instagram" />
				</a>
				<a class="hr-social-icon-link" href="https://www.facebook.com/people/HackerRank-Crew-GDL/61580737153824/" target="_blank" rel="noreferrer noopener" aria-label="Facebook">
					<SocialIcon name="facebook" />
				</a>
				<a class="hr-social-icon-link" href="https://www.youtube.com/channel/UCU1GwiscWovSP0xS5xBL2iA" target="_blank" rel="noreferrer noopener" aria-label="YouTube">
					<SocialIcon name="youtube" />
				</a>
			</nav>
		</div>
	</footer>
</div>