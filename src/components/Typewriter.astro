---
interface Props {
	text: string; // Initial text
	phrases?: string[]; // List of phrases to cycle through
	delay?: number; // Delay before starting the first animation
	speed?: number; // Typing speed
	eraseSpeed?: number; // Backspacing speed
	minWait?: number; // Minimum wait time before changing phrase
	maxWait?: number; // Maximum wait time before changing phrase
}

const { 
	text, 
	phrases = [], 
	delay = 500, 
	speed = 120, 
	eraseSpeed = 60,
	minWait = 2000,
	maxWait = 5000 
} = Astro.props;

// Combine initial text with phrases if they are not already there
const allPhrases = [text, ...phrases.filter(p => p !== text)];
---

<div 
	class="typewriter-wrapper" 
	data-phrases={JSON.stringify(allPhrases)}
	data-speed={speed} 
	data-erase-speed={eraseSpeed}
	data-delay={delay}
	data-min-wait={minWait}
	data-max-wait={maxWait}
>
	<!-- Accessible text for screen readers (using the initial text) -->
	<span class="hr-sr-only">{text}</span>
	
	<!-- Visual animation hidden from screen readers -->
	<div class="typewriter-container" aria-hidden="true">
		<!-- Invisible ghost text to reserve layout space (using the longest phrase to avoid jumps) -->
		<span class="typewriter-ghost">{allPhrases.reduce((a, b) => a.length > b.length ? a : b)}</span>
		
		<!-- Dynamically revealed text -->
		<span class="typewriter-typed"></span>

		<!-- Dynamic cursor -->
		<div class="typewriter-cursor-wrapper">
			<div class="typewriter-cursor-block"></div>
			<span class="typewriter-cursor-letter"></span>
		</div>
	</div>
</div>

<script>
	function initTypewriter() {
		const wrappers = document.querySelectorAll('.typewriter-wrapper');
		
		wrappers.forEach(wrapper => {
			const container = wrapper.querySelector('.typewriter-container');
			if (!container) return;

			const typedEl = container.querySelector('.typewriter-typed') as HTMLElement;
			const cursorWrapper = container.querySelector('.typewriter-cursor-wrapper') as HTMLElement;
			const cursorLetter = container.querySelector('.typewriter-cursor-letter') as HTMLElement;
			
			const phrases = JSON.parse(wrapper.getAttribute('data-phrases') || '[]');
			const speed = parseInt(wrapper.getAttribute('data-speed') || '120');
			const eraseSpeed = parseInt(wrapper.getAttribute('data-erase-speed') || '60');
			const initialDelay = parseInt(wrapper.getAttribute('data-delay') || '500');
			const minWait = parseInt(wrapper.getAttribute('data-min-wait') || '2000');
			const maxWait = parseInt(wrapper.getAttribute('data-max-wait') || '5000');
			
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			let phraseIndex = 0;
			let charIndex = 0;
			let isDeleting = false;

			// Reset to clean state
			typedEl.textContent = '';
			cursorLetter.textContent = '';
			cursorWrapper.classList.remove('blink');

			if (prefersReducedMotion) {
				typedEl.textContent = phrases[0];
				cursorWrapper.style.display = 'none';
				return;
			}

			function getRandomWait() {
				return Math.floor(Math.random() * (maxWait - minWait + 1)) + minWait;
			}

			function tick() {
				const currentPhrase = phrases[phraseIndex];
				
				if (isDeleting) {
					// Erasing logic
					charIndex--;
					typedEl.textContent = currentPhrase.slice(0, charIndex);
					
					// Position cursor at the end of current visible text
					const currentWidth = typedEl.getBoundingClientRect().width;
					cursorWrapper.style.transform = `translateX(${currentWidth}px)`;
					
					// During deletion, show the letter being deleted or keep it empty
					cursorLetter.textContent = currentPhrase[charIndex] || '';
					cursorWrapper.classList.remove('blink');

					if (charIndex <= 0) {
						isDeleting = false;
						phraseIndex = (phraseIndex + 1) % phrases.length;
						setTimeout(tick, 500); // Small pause before typing next
						return;
					}
					
					setTimeout(tick, eraseSpeed);
				} else {
					// Typing logic
					typedEl.textContent = currentPhrase.slice(0, charIndex);
					
					const currentWidth = typedEl.getBoundingClientRect().width;
					cursorWrapper.style.transform = `translateX(${currentWidth}px)`;
					
					if (charIndex < currentPhrase.length) {
						cursorLetter.textContent = currentPhrase[charIndex];
						cursorWrapper.classList.remove('blink');
						charIndex++;
						setTimeout(tick, speed);
					} else {
						// Phrase complete
						cursorLetter.textContent = '';
						cursorWrapper.classList.add('blink');
						isDeleting = true;
						setTimeout(tick, getRandomWait());
					}
				}
			}

			setTimeout(tick, initialDelay);
		});
	}

	initTypewriter();
	document.addEventListener('astro:after-swap', initTypewriter);
</script>
