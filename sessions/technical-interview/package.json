{
  "name": "technical-interview",
  "type": "module",
  "private": true,
  "dependencies": {
    "@hr-gdl/shared-assets": "workspace:*"
  },
  "scripts": {
    "prebuild": "mkdir -p public && cp -r ../../../node_modules/@hr-gdl/shared-assets/dist/* public/",
    "build": "npm run prebuild && slidev build --base /slides/technical-interview/",
    "dev": "npm run prebuild && slidev --port 3032 --base /slides/technical-interview/",
    "export": "slidev export"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "latest",
    "vue": "^3.5.29"
  }
}